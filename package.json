{
  "name": "pglogstats",
  "version": "0.1.0",
  "description": "Statically generated paragliding flight statistics report (IGC -> SPA)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
