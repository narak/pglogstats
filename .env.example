# Copy to .env and fill in. Do NOT commit the real .env.
# For CI, set the same values as GitHub repo secrets.

# --- Telegram capture (npm run telegram:poll) ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Your chat id — the only chat the bot accepts .igc files from.
TELEGRAM_CHAT_ID=

# --- Google Drive archive (optional backup of each captured .igc) ---
# Folder that receives the archive copy. Also used by `npm run data:drive`.
GDRIVE_FOLDER_ID=

# Service-account key, as a single line of JSON. For the Telegram archive the
# service account needs Editor (write) access to GDRIVE_FOLDER_ID; readonly is
# enough only for `npm run data:drive`.
# e.g. GDRIVE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
GDRIVE_SERVICE_ACCOUNT=

# Optional: GitHub personal access token, only if you push updated data
# from a local run instead of relying on the GitHub Actions workflow.
GH_PAT=
