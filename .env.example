# Copy to .env and fill in for `npm run data:drive`. Do NOT commit the real .env.

# Google Drive folder containing your .igc files.
GDRIVE_FOLDER_ID=

# Drive read-only service-account key, as a single line of JSON.
# e.g. GDRIVE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
GDRIVE_SERVICE_ACCOUNT=

# Optional: GitHub personal access token, only if you push updated data
# from a local run instead of relying on the GitHub Actions workflow.
GH_PAT=
